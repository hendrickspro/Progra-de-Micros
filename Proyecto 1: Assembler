; ------------------------------------------------------------------------------
; MuxAlarma - Multiplexado HH:MM alarma (modo 4)
; Datos de registros HoraDecA/HoraUniA/MinDecA/MinUniA
; ------------------------------------------------------------------------------
MuxAlarma:
    cpi  mux, 1
    breq JmpMuxAlarmaHoraUni
    cpi  mux, 2
    breq JmpMuxAlarmaMinDec
    cpi  mux, 3
    breq JmpMuxAlarmaMinUni
    rjmp MuxAlarmaHoraDec
    JmpMuxAlarmaHoraUni:
        rjmp MuxAlarmaHoraUni
    JmpMuxAlarmaMinDec:
        rjmp MuxAlarmaMinDec
    JmpMuxAlarmaMinUni:
        rjmp MuxAlarmaMinUni

    MuxAlarmaHoraDec:
        mov  temp, HoraDecA
        rcall GetPattern
        tst  grupo
        breq MuxAlarmaHoraDecSkip
        out  PORTD, temp
        sbi  PORTC, PC0
        MuxAlarmaHoraDecSkip:
            ldi  mux, 1
            rjmp UpdateTime

    MuxAlarmaHoraUni:
        mov  temp, HoraUniA
        rcall GetPattern
        tst  grupo
        breq MuxAlarmaHoraUniSkip
        out  PORTD, temp
        sbi  PORTC, PC1
        MuxAlarmaHoraUniSkip:
            ldi  mux, 2
            rjmp UpdateTime

    MuxAlarmaMinDec:
        mov  temp, MinDecA
        rcall GetPattern
        tst  grupo
        brne MuxAlarmaMinDecSkip
        out  PORTD, temp
        sbi  PORTC, PC2
        MuxAlarmaMinDecSkip:
            ldi  mux, 3
            rjmp UpdateTime

    MuxAlarmaMinUni:
        mov  temp, MinUniA
        rcall GetPattern
        tst  grupo
        brne MuxAlarmaMinUniSkip
        out  PORTD, temp
        sbi  PORTC, PC3
        MuxAlarmaMinUniSkip:
            ldi  mux, 0

; ------------------------------------------------------------------------------
; UpdateTime - Incrementa el tiempo (solo en modo 0)
; Cadena: MsLow(250) -> MsHigh(4) -> Seg(60) -> Min -> Hora
; Al llegar a 60seg setea MinutoCambio=1 para disparo de alarma
; ------------------------------------------------------------------------------
UpdateTime:
    cpi  modo, 0
    breq UpdateTimeContinue
    rjmp CheckAlarma

    UpdateTimeContinue:
        lds  temp, MsLow
        inc  temp
        sts  MsLow, temp
        cpi  temp, 250
        brne UpdateTimeMsLowSkip
        rjmp UpdateTimeMsLowDone
        UpdateTimeMsLowSkip:
            rjmp CheckAlarma
        UpdateTimeMsLowDone:
            sts  MsLow, r1

        lds  temp, MsHigh
        inc  temp
        sts  MsHigh, temp
        cpi  temp, 4
        brne UpdateTimeMsHighSkip
        rjmp UpdateTimeMsHighDone
        UpdateTimeMsHighSkip:
            rjmp CheckAlarma
        UpdateTimeMsHighDone:
            sts  MsHigh, r1

        lds  temp, Segundos
        inc  temp
        sts  Segundos, temp
        cpi  temp, 60
        brne UpdateTimeSegSkip
        rjmp UpdateTimeSegDone
        UpdateTimeSegSkip:
            rjmp CheckAlarma
        UpdateTimeSegDone:
            sts  Segundos, r1
            ldi  temp, 1
            sts  MinutoCambio, temp     ; Avisar cambio de minuto

        lds  temp, MinUni
        inc  temp
        sts  MinUni, temp
        cpi  temp, 10
        brne UpdateTimeMinUniSkip
        rjmp UpdateTimeMinUniDone
        UpdateTimeMinUniSkip:
            rjmp CheckAlarma
        UpdateTimeMinUniDone:
            sts  MinUni, r1

        lds  temp, MinDec
        inc  temp
        sts  MinDec, temp
        cpi  temp, 6
        brne UpdateTimeMinDecSkip
        rjmp UpdateTimeMinDecDone
        UpdateTimeMinDecSkip:
            rjmp CheckAlarma
        UpdateTimeMinDecDone:
            sts  MinDec, r1

        lds  temp, HoraUni
        inc  temp
        sts  HoraUni, temp
        cpi  temp, 10
        brne UpdateTimeCheckHora24
        sts  HoraUni, r1
        lds  temp, HoraDec
        inc  temp
        sts  HoraDec, temp
        rjmp CheckAlarma

        UpdateTimeCheckHora24:
            lds  temp, HoraDec
            cpi  temp, 2
            brne JmpCheckAlarma
            lds  temp, HoraUni
            cpi  temp, 4
            brne JmpCheckAlarma
            sts  HoraUni, r1
            sts  HoraDec, r1
            rjmp CheckAlarma
            JmpCheckAlarma:
                rjmp CheckAlarma

; ------------------------------------------------------------------------------
; CheckAlarma - Manejo de alarma
; AlarmOn=1: buzzer sigue blink (pitido intermitente cada 500ms)
; AlarmOn=0: comparar hora con alarma al cambiar minuto
; PB1 en Main apaga la alarma
; ------------------------------------------------------------------------------
CheckAlarma:
    lds  temp, AlarmOn
    tst  temp
    breq CheckAlarmaComparar

    ; Alarma activa -> buzzer sigue blink
    tst  blink
    breq CheckAlarmaBuzzerOff
    sbi  PORTD, PD7
    rjmp CheckAlarmaFin
    CheckAlarmaBuzzerOff:
        cbi  PORTD, PD7
        rjmp CheckAlarmaFin

    CheckAlarmaComparar:
        ; Solo comparar cuando el minuto acaba de cambiar
        lds  temp, MinutoCambio
        tst  temp
        breq CheckAlarmaFin
        sts  MinutoCambio, r1
        lds  temp, HoraUni
        cp   temp, HoraUniA
        brne CheckAlarmaFin
        lds  temp, HoraDec
        cp   temp, HoraDecA
        brne CheckAlarmaFin
        lds  temp, MinUni
        cp   temp, MinUniA
        brne CheckAlarmaFin
        lds  temp, MinDec
        cp   temp, MinDecA
        brne CheckAlarmaFin
        ldi  temp, 1
        sts  AlarmOn, temp      ; Coincidencia -> activar alarma

    CheckAlarmaFin:
IsrEnd:
    pop  temp
    out  SREG, temp
    pop  temp
    reti

; ==============================================================================
; SUBRUTINA: GetPattern
; Entrada: temp = digito (0-9)
; Salida:  temp = patron 7 segmentos
; ==============================================================================
GetPattern:
    push r30
    push r31
    ldi  ZH, high(Table7Seg<<1)
    ldi  ZL, low(Table7Seg<<1)
    add  ZL, temp
    adc  ZH, r1
    lpm  temp, Z
    pop  r31
    pop  r30
    ret
